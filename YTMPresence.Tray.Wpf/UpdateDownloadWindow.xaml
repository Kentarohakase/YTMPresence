<Window x:Class="YTMPresence.TrayWpf.UpdateDownloadWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="YTM Presence Update"
        Width="520"
        Height="300"
        MinWidth="480"
        MinHeight="280"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Update installieren"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Margin="0,0,0,10" />

        <TextBlock x:Name="SummaryText"
                   Grid.Row="1"
                   TextWrapping="Wrap"
                   Margin="0,0,0,14" />

        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Setup-Datei" />
            <TextBlock x:Name="SetupFileText"
                       Grid.Row="0"
                       Grid.Column="1"
                       TextWrapping="Wrap" />

            <TextBlock Grid.Row="1"
                       Grid.Column="0"
                       Text="Ziel"
                       Margin="0,8,0,0" />
            <TextBlock x:Name="TargetPathText"
                       Grid.Row="1"
                       Grid.Column="1"
                       Margin="0,8,0,0"
                       TextWrapping="Wrap" />
        </Grid>

        <StackPanel Grid.Row="3">
            <ProgressBar x:Name="DownloadProgress"
                         Height="18"
                         Minimum="0"
                         Maximum="100"
                         Value="0" />
            <TextBlock x:Name="ProgressText"
                       Margin="0,8,0,0"
                       TextWrapping="Wrap" />
            <TextBlock x:Name="StatusText"
                       Margin="0,8,0,0"
                       Foreground="#0a7a2f"
                       TextWrapping="Wrap" />
        </StackPanel>

        <DockPanel Grid.Row="4" LastChildFill="False">
            <Button x:Name="CancelButton"
                    Content="Abbrechen"
                    Width="96"
                    Margin="8,0,0,0"
                    DockPanel.Dock="Right"
                    IsCancel="True"
                    Click="CancelButton_Click" />
            <Button x:Name="OpenReleaseButton"
                    Content="Release öffnen"
                    Width="112"
                    Margin="8,0,0,0"
                    DockPanel.Dock="Right"
                    Click="OpenReleaseButton_Click" />
            <Button x:Name="InstallButton"
                    Content="Herunterladen und installieren"
                    Width="178"
                    DockPanel.Dock="Right"
                    Click="InstallButton_Click" />
        </DockPanel>
    </Grid>
</Window>
