<Window x:Class="YTMPresence.TrayWpf.PlayerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="YTM Presence Player"
        Width="520"
        Height="250"
        MinWidth="460"
        MinHeight="220"
        WindowStartupLocation="Manual"
        ResizeMode="CanResizeWithGrip"
        Background="#101010">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F4F4F4" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#D92323" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="MinHeight" Value="32" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#D8D8D8" />
        </Style>
    </Window.Resources>

    <Border Margin="14"
            CornerRadius="10"
            Background="#181818"
            Padding="16">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Width="136"
                    Height="136"
                    CornerRadius="8"
                    Background="#282828"
                    VerticalAlignment="Top"
                    ClipToBounds="True">
                <Grid>
                    <Image x:Name="CoverImage"
                           Stretch="UniformToFill"
                           ClipToBounds="True" />
                    <TextBlock x:Name="CoverFallbackText"
                               Text="YTM"
                               Foreground="#F4F4F4"
                               FontSize="26"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Grid>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" LastChildFill="True" Margin="0,0,0,6">
                    <CheckBox x:Name="TopMostBox"
                              DockPanel.Dock="Right"
                              Content="Top"
                              VerticalAlignment="Center"
                              Margin="10,0,0,0"
                              Checked="TopMostBox_Changed"
                              Unchecked="TopMostBox_Changed" />
                    <TextBlock x:Name="TitleText"
                               FontSize="20"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" />
                </DockPanel>

                <TextBlock x:Name="ArtistText"
                           Grid.Row="1"
                           Foreground="#BDBDBD"
                           FontSize="14"
                           TextTrimming="CharacterEllipsis"
                           Margin="0,0,0,2" />

                <TextBlock x:Name="AlbumText"
                           Grid.Row="2"
                           Foreground="#8F8F8F"
                           FontSize="12"
                           TextTrimming="CharacterEllipsis"
                           Margin="0,0,0,14" />

                <Grid Grid.Row="3">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <ProgressBar x:Name="Progress"
                                 Height="7"
                                 Minimum="0"
                                 Maximum="1"
                                 Value="0"
                                 Foreground="#D92323"
                                 Background="#303030"
                                 BorderThickness="0" />

                    <DockPanel Grid.Row="1" Margin="0,7,0,0">
                        <TextBlock x:Name="PositionText"
                                   DockPanel.Dock="Left"
                                   Foreground="#A8A8A8"
                                   FontSize="12" />
                        <TextBlock x:Name="DurationText"
                                   DockPanel.Dock="Right"
                                   Foreground="#A8A8A8"
                                   FontSize="12" />
                        <TextBlock x:Name="PlayStateText"
                                   HorizontalAlignment="Center"
                                   Foreground="#D8D8D8"
                                   FontSize="12" />
                    </DockPanel>
                </Grid>

                <Grid Grid.Row="4"
                      VerticalAlignment="Bottom">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="CommandStatusText"
                               Foreground="#8F8F8F"
                               FontSize="12"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" />

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button x:Name="PreviousButton"
                                Content="&lt;&lt;"
                                ToolTip="Zurück"
                                MinWidth="44"
                                Margin="0,0,8,0"
                                Click="PreviousButton_Click" />
                        <Button x:Name="PlayPauseButton"
                                Content="Play"
                                ToolTip="Play/Pause"
                                MinWidth="72"
                                Margin="0,0,8,0"
                                Click="PlayPauseButton_Click" />
                        <Button x:Name="NextButton"
                                Content="&gt;&gt;"
                                ToolTip="Weiter"
                                MinWidth="44"
                                Margin="0,0,8,0"
                                Click="NextButton_Click" />
                        <Button x:Name="OpenTrackButton"
                                Content="Öffnen"
                                ToolTip="Track öffnen"
                                MinWidth="86"
                                Click="OpenTrackButton_Click" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
