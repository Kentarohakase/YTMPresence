<Window x:Class="YTMPresence.TrayWpf.PlayerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="YTM Presence Player"
        Width="420"
        Height="220"
        MinWidth="380"
        MinHeight="200"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="132" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Width="120"
                Height="120"
                CornerRadius="8"
                Background="#202020"
                VerticalAlignment="Top">
            <Grid>
                <Image x:Name="CoverImage"
                       Stretch="UniformToFill"
                       ClipToBounds="True" />
                <TextBlock x:Name="CoverFallbackText"
                           Text="YTM"
                           Foreground="White"
                           FontSize="24"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock x:Name="TitleText"
                       FontSize="18"
                       FontWeight="SemiBold"
                       TextTrimming="CharacterEllipsis"
                       Margin="0,0,0,4" />

            <TextBlock x:Name="ArtistText"
                       Grid.Row="1"
                       Foreground="#555"
                       TextTrimming="CharacterEllipsis"
                       Margin="0,0,0,2" />

            <TextBlock x:Name="AlbumText"
                       Grid.Row="2"
                       Foreground="#777"
                       TextTrimming="CharacterEllipsis"
                       Margin="0,0,0,12" />

            <Grid Grid.Row="3">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ProgressBar x:Name="Progress"
                             Height="8"
                             Minimum="0"
                             Maximum="1"
                             Value="0" />

                <DockPanel Grid.Row="1" Margin="0,6,0,0">
                    <TextBlock x:Name="PositionText"
                               DockPanel.Dock="Left"
                               Foreground="#555"
                               FontSize="12" />
                    <TextBlock x:Name="DurationText"
                               DockPanel.Dock="Right"
                               Foreground="#555"
                               FontSize="12" />
                    <TextBlock x:Name="PlayStateText"
                               HorizontalAlignment="Center"
                               Foreground="#333"
                               FontSize="12" />
                </DockPanel>
            </Grid>

            <StackPanel Grid.Row="4"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom">
                <Button x:Name="OpenTrackButton"
                        Content="Track öffnen"
                        MinWidth="108"
                        Click="OpenTrackButton_Click" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
